{deps,
 [{cowboy, "2.10.0"},
  {jsx, "v2.11.0"},       % jsx 3 causes test failures; stay with v2 for now
  {esqlite, "~> 0.9"}
 ]
}.
{erl_first_files, ["src/gc.erl"]}.
{erl_opts, [debug_info, nowarn_unused_vars, nowarn_shadow_vars]}.
{minimum_otp_vsn, "21"}.

